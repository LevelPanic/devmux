{
  "name": "devmux-cli",
  "version": "0.2.0",
  "description": "Run multiple dev sessions across git worktrees — zero config, auto-detects everything",
  "type": "module",
  "bin": {
    "devmux": "./bin/devmux.js"
  },
  "exports": {
    ".": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "tsc"
  },
  "files": [
    "dist",
    "!dist/**/*.js.map",
    "bin",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "dev",
    "devserver",
    "worktree",
    "git-worktree",
    "multiplexer",
    "parallel",
    "development",
    "cli",
    "monorepo",
    "process-manager",
    "terminal",
    "nextjs",
    "vite",
    "remix"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LevelPanic/devmux.git"
  },
  "homepage": "https://github.com/LevelPanic/devmux#readme",
  "bugs": {
    "url": "https://github.com/LevelPanic/devmux/issues"
  },
  "author": "LevelPanic",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
